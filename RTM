class Robot:
    def __init__(self, name, battery=100):
        self.name = name
        self.battery = battery
        self.tasks_completed = []  # List to track tasks
        self.task_details = {}     # Dictionary to track task info

    def greet(self):
        print(f"\nHello! I am {self.name}, battery: {self.battery}%")

    def do_task(self, task):
        if self.battery <= 0:
            print(f"{self.name} has no battery! Charge first.")
            return
 {
         Control flow for battery              warning
 {
        if self.battery < 20:
            print(f"{self.name} is low on battery. Doing {task} slowly...")
        else:
            print(f"{self.name} is performing {task} quickly!")
{
         Update task list and details
{
     self.tasks_completed.append(task)
        self.task_details[task] = self.task_details.get(task, 0) + 1
{
        Reduce battery
{
        self.battery -= 10
        if self.battery < 0:
            self.battery = 0

    def charge(self):
        print(f"{self.name} is charging...")
        self.battery = 100

    def show_tasks(self):
        print(f"\nTasks completed by {self.name}:")
        if not self.tasks_completed:
            print("No tasks done yet.")
        else:
            for task, count in self.task_details.items():
                print(f"- {task}: {count} time(s)")
