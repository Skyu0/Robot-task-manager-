def assign_task(robot):
    task = input("Enter a task for the robot (clean/paint/compute): ").lower()
{
    Control flow for unknown tasks
{
    if task not in ["clean", "paint", "compute"]:
        print("Unknown task. Robot will idle.")
        task = "idle"
    
    robot.do_task(task)
